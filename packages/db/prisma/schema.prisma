generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "driverAdapters"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Auth ────────────────────────────────────────────────
model User {
  id            String  @id @default(cuid())
  email         String  @unique
  emailVerified Boolean @default(false)
  name          String?
  image         String?
  credits       Int     @default(100)

  boards   Board[]
  sessions Session[]
  accounts Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Boards ──────────────────────────────────────────────
model Board {
  id               String  @id @default(cuid())
  title            String
  thumbnailUrl     String?
  owner            User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId          String
  liveblocksRoomId String  @unique
  githubRepo       String? // "owner/repo" format
  githubToken      String? // encrypted PAT

  discoveries   Discovery[]
  conversations Conversation[]
  prds          PRD[]
  meetingNotes  MeetingNote[]
  specs         Spec[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// ─── Discovery Sessions ──────────────────────────────────
model Discovery {
  id         String @id @default(cuid())
  board      Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId    String
  sourceType String // "transcript" | "audio" | "notes"
  rawContent String @db.Text
  status     String @default("pending") // pending | processing | completed | failed

  insights Insight[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model Insight {
  id          String    @id @default(cuid())
  discovery   Discovery @relation(fields: [discoveryId], references: [id], onDelete: Cascade)
  discoveryId String
  category    String // pain_point | feature_request | praise | question
  content     String    @db.Text
  quote       String?   @db.Text
  sentiment   Float?
  layerId     String? // Maps to Tldraw shape on canvas

  // pgvector embedding for semantic search (1536 = OpenAI text-embedding-3-small)
  // Adjust dimension if switching to a different embedding model
  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now())

  @@index([discoveryId])
}

// ─── PRDs ────────────────────────────────────────────────
model PRD {
  id      String @id @default(cuid())
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  title   String
  content String @db.Text
  status  String @default("draft") // draft | review | approved

  specs Spec[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

// ─── Specs ───────────────────────────────────────────────
model Spec {
  id         String  @id @default(cuid())
  board      Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId    String
  prd        PRD?    @relation(fields: [prdId], references: [id])
  prdId      String?
  title      String
  content    String  @db.Text
  shapeId    String? // linked FeatureCard on canvas
  status     String  @default("draft") // draft | review | approved | shipped
  complexity String? // xs | s | m | l | xl

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
  @@index([prdId])
}

// ─── Tasks ───────────────────────────────────────────────
model Task {
  id             String  @id @default(cuid())
  spec           Spec    @relation(fields: [specId], references: [id], onDelete: Cascade)
  specId         String
  title          String
  description    String  @db.Text
  complexity     String? // xs | s | m | l | xl
  githubIssueUrl String?
  githubIssueId  Int?
  status         String  @default("todo") // todo | in_progress | done

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([specId])
}

// ─── Meeting Notes ───────────────────────────────────────
model MeetingNote {
  id      String @id @default(cuid())
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  title   String
  content String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

// ─── AI Conversations ────────────────────────────────────
model Conversation {
  id      String @id @default(cuid())
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  title   String @default("New Conversation")

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model Message {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  role           String // user | assistant | system
  content        String       @db.Text
  status         String? // processing | completed | cancelled

  createdAt DateTime @default(now())

  @@index([conversationId])
}
