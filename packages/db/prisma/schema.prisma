generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum OrganizationRole {
  owner
  admin
  editor
  viewer
}

enum OrganizationMembershipStatus {
  active
  invited
  suspended
}

enum OrganizationInvitationStatus {
  pending
  accepted
  revoked
  expired
}

// ─── Auth ────────────────────────────────────────────────
model User {
  id                   String  @id @default(cuid())
  email                String  @unique
  emailVerified        Boolean @default(false)
  name                 String?
  image                String?
  credits              Int     @default(100)
  activeOrganizationId String?

  activeOrganization         Organization?           @relation("ActiveOrganization", fields: [activeOrganizationId], references: [id], onDelete: SetNull)
  createdBoards              Board[]                 @relation("CreatedBoards")
  createdOrganizations       Organization[]          @relation("CreatedOrganizations")
  organizationMemberships    OrganizationMembership[]
  sentOrganizationInvites    OrganizationInvitation[] @relation("OrganizationInvitationsSent")
  sessions                   Session[]
  accounts                   Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activeOrganizationId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Organizations ───────────────────────────────────────
model Organization {
  id              String  @id @default(cuid())
  name            String
  slug            String  @unique
  credits         Int     @default(100)
  createdByUserId String?

  activeUsers  User[]                  @relation("ActiveOrganization")
  boards       Board[]
  createdBy    User?                   @relation("CreatedOrganizations", fields: [createdByUserId], references: [id], onDelete: SetNull)
  invitations  OrganizationInvitation[]
  memberships  OrganizationMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdByUserId])
}

model OrganizationMembership {
  id             String                       @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole            @default(editor)
  status         OrganizationMembershipStatus @default(active)
  joinedAt       DateTime                    @default(now())
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model OrganizationInvitation {
  id               String                       @id @default(cuid())
  organizationId   String
  email            String
  role             OrganizationRole            @default(editor)
  status           OrganizationInvitationStatus @default(pending)
  token            String                       @unique
  expiresAt        DateTime
  acceptedAt       DateTime?
  invitedByUserId  String?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  invitedBy    User?         @relation("OrganizationInvitationsSent", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([organizationId, email])
}

// ─── Boards ──────────────────────────────────────────────
model Board {
  id               String       @id @default(cuid())
  title            String
  thumbnailUrl     String?
  organizationId   String
  createdById      String?
  liveblocksRoomId String       @unique
  githubRepo       String? // "owner/repo" format
  githubToken      String? // encrypted PAT

  createdBy    User?         @relation("CreatedBoards", fields: [createdById], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  discoveries   Discovery[]
  conversations Conversation[]
  prds          PRD[]
  meetingNotes  MeetingNote[]
  specs         Spec[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([createdById])
}

// ─── Discovery Sessions ──────────────────────────────────
model Discovery {
  id         String @id @default(cuid())
  board      Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId    String
  sourceType String // "transcript" | "audio" | "notes"
  rawContent String @db.Text
  status     String @default("pending") // pending | processing | completed | failed

  insights Insight[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model Insight {
  id          String    @id @default(cuid())
  discovery   Discovery @relation(fields: [discoveryId], references: [id], onDelete: Cascade)
  discoveryId String
  category    String // pain_point | feature_request | praise | question
  content     String    @db.Text
  quote       String?   @db.Text
  sentiment   Float?
  layerId     String? // Maps to Tldraw shape on canvas

  // pgvector embedding for semantic search (1536 = OpenAI text-embedding-3-small)
  // Adjust dimension if switching to a different embedding model
  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now())

  @@index([discoveryId])
}

// ─── PRDs ────────────────────────────────────────────────
model PRD {
  id      String @id @default(cuid())
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  title   String
  content String @db.Text
  status  String @default("draft") // draft | review | approved

  specs Spec[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

// ─── Specs ───────────────────────────────────────────────
model Spec {
  id         String  @id @default(cuid())
  board      Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId    String
  prd        PRD?    @relation(fields: [prdId], references: [id])
  prdId      String?
  title      String
  content    String  @db.Text
  shapeId    String? // linked FeatureCard on canvas
  status     String  @default("draft") // draft | review | approved | shipped
  complexity String? // xs | s | m | l | xl

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
  @@index([prdId])
}

// ─── Tasks ───────────────────────────────────────────────
model Task {
  id             String  @id @default(cuid())
  spec           Spec    @relation(fields: [specId], references: [id], onDelete: Cascade)
  specId         String
  title          String
  description    String  @db.Text
  complexity     String? // xs | s | m | l | xl
  githubIssueUrl String?
  githubIssueId  Int?
  status         String  @default("todo") // todo | in_progress | done

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([specId])
}

// ─── Meeting Notes ───────────────────────────────────────
model MeetingNote {
  id      String @id @default(cuid())
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  title   String
  content String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

// ─── AI Conversations ────────────────────────────────────
model Conversation {
  id      String @id @default(cuid())
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  title   String @default("New Conversation")

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([boardId])
}

model Message {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  role           String // user | assistant | system
  content        String       @db.Text
  status         String? // processing | completed | cancelled

  createdAt DateTime @default(now())

  @@index([conversationId])
}
